{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "ignorePatterns": [
    "**/*.md",
    "**/*.mdx",
    "**/__fixtures__/**",
    "**/__snapshots__/**",
    "**/tsconfig*.json",
    "**/turbo.json",
    "**/.release-it.json",
    "**/*.yml",
    "**/*.yaml",
    "**/*.html",
    "**/*.json",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.mts",
    "**/*.test-d.ts",
    "**/*.test-d.tsx",
    "**/tests/**",
    "**/vitest.config.*",
    ".changeset/**",
    ".devcontainer/**",
    ".github/**",
    ".vscode/**",
    "docs/**",
    "examples/**",
    "internal/**",
    "libs/langgraph-api/src/graph/parser/schema/types.mts",
    "libs/langgraph-api/src/graph/parser/schema/types.template.mts",
  ],
  "jsxSingleQuote": false,
  "printWidth": 80,
  "quoteProps": "as-needed",
  "semi": true,
  "singleQuote": false,
  "sortPackageJson": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false,
}
