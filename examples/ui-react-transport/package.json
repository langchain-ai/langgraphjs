{
  "name": "@examples/ui-react-transport",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev:client dev:server",
    "dev:client": "vite",
    "dev:server": "tsx watch --env-file=.env --clear-screen=false src/server.mts",
    "build:internal": "tsc -b && vite build",
    "format": "prettier --write src",
    "lint": "prettier --check src",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "workspace:*",
    "@langchain/react": "workspace:*",
    "@langchain/openai": "^1.2.12",
    "hono": "^4.12.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.4.1",
    "prettier": "^2.8.3",
    "tsx": "^4.19.3",
    "typescript": "^5.4.5",
    "vite": "^7.0.0"
  }
}
