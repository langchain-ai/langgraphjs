{
  "name": "@langchain/svelte",
  "version": "0.4.5",
  "description": "Svelte integration for LangGraph & LangChain",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist/ dist-cjs/",
    "build": "pnpm turbo build:internal --filter=@langchain/svelte",
    "build:internal": "pnpm --filter @langchain/build compile @langchain/svelte",
    "prepublish": "pnpm build",
    "lint:eslint": "NODE_OPTIONS=--max-old-space-size=4096 eslint --cache --ext .ts,.js,.jsx,.tsx src/",
    "test": "vitest run"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/langchain-ai/langgraphjs.git",
    "directory": "libs/sdk-svelte"
  },
  "dependencies": {
    "@langchain/langgraph-sdk": "workspace:^"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.13",
    "@langchain/core": "^1.1.38",
    "@langchain/langgraph": "workspace:^",
    "@langchain/langgraph-api": "workspace:^",
    "@langchain/langgraph-checkpoint": "workspace:^",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.4.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-webdriverio": "^4.0.18",
    "deepagents": "^1.8.3",
    "hono": "^4.12.12",
    "langchain": "^1.3.0",
    "svelte": "^5.55.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-browser-svelte": "^2.1.0",
    "webdriverio": "^9.25.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@langchain/core": "^1.1.27",
    "svelte": "^5.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "input": "./src/index.ts",
      "typedoc": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ]
}
