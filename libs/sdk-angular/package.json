{
  "name": "@langchain/angular",
  "version": "0.1.1",
  "description": "Angular integration for LangGraph & LangChain",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist/ dist-cjs/",
    "build": "pnpm turbo build:internal --filter=@langchain/angular",
    "build:internal": "pnpm --filter @langchain/build compile @langchain/angular",
    "prepublish": "pnpm build",
    "format:check": "prettier --check src",
    "format": "prettier --write src",
    "lint:eslint": "NODE_OPTIONS=--max-old-space-size=4096 eslint --cache --ext .ts,.js,.jsx,.tsx src/",
    "lint": "pnpm lint:eslint",
    "lint:fix": "pnpm lint:eslint --fix",
    "test": "vitest run"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/langchain-ai/langgraphjs.git",
    "directory": "libs/sdk-angular"
  },
  "dependencies": {
    "@langchain/langgraph-sdk": "workspace:^"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@analogjs/vitest-angular": "^2.3.1",
    "@angular/compiler": "^21.2.2",
    "@angular/core": "^21.2.2",
    "@angular/platform-browser": "^21.2.2",
    "@angular/platform-browser-dynamic": "^21.2.2",
    "@angular/router": "^21.2.2",
    "@hono/node-server": "^1.19.11",
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "workspace:^",
    "@langchain/langgraph-api": "workspace:^",
    "@langchain/langgraph-checkpoint": "workspace:^",
    "@langchain/scripts": "^0.1.4",
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^25.4.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-webdriverio": "^4.0.18",
    "deepagents": "^1.8.1",
    "eslint": "^8.33.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-instanceof": "^1.0.1",
    "eslint-plugin-prettier": "^4.2.1",
    "hono": "^4.12.7",
    "langchain": "^1.2.30",
    "prettier": "^3.8.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-browser-angular": "^0.3.0",
    "webdriverio": "^9.25.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@angular/core": "^18.0.0 || ^19.0.0 || ^20.0.0",
    "@langchain/core": "^1.1.27"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "input": "./src/index.ts",
      "typedoc": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ]
}
