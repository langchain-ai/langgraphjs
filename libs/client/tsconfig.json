{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2021",
      "ES2022.Array",
      "ES2022.Object",
      "ES2022.Error",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
