# Oracle Database credentials for integration tests.
# Copy to .env or export these variables in your shell before running:
# pnpm --filter @oracle/langgraph-oracledb test:int

ORACLE_USER=user1
ORACLE_PASSWORD=user1
ORACLE_CONNECT_STRING=localhost:1521/FREEPDB1

# Optional. Tests append table suffixes to this prefix.
# Must start with a letter and contain only letters, numbers, or underscores.
ORACLE_LANGGRAPH_TABLE_PREFIX=LG_ORACLE_TEST_
