{
  "name": "@langchain/react",
  "version": "1.0.26",
  "description": "React integration for LangGraph & LangChain",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist/ dist-cjs/",
    "build": "pnpm turbo build:internal --filter=@langchain/react",
    "build:internal": "pnpm --filter @langchain/build compile @langchain/react",
    "prepublish": "pnpm build",
    "lint:eslint": "NODE_OPTIONS=--max-old-space-size=4096 eslint --cache --ext .ts,.js,.jsx,.tsx src/",
    "test": "vitest run"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/langchain-ai/langgraphjs.git",
    "directory": "libs/sdk-react"
  },
  "dependencies": {
    "@langchain/langgraph-sdk": "workspace:*"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.13",
    "@hono/node-ws": "^1.3.0",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "workspace:^",
    "@langchain/langgraph-api": "workspace:^",
    "@langchain/langgraph-checkpoint": "workspace:^",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-webdriverio": "^4.1.9",
    "deepagents": "^1.10.5",
    "hono": "^4.12.25",
    "langchain": "^1.5.2",
    "react": "^19.2.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0",
    "webdriverio": "^9.25.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@langchain/core": "^1.1.48",
    "react": "^18 || ^19"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "input": "./src/index.ts",
      "typedoc": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ]
}
